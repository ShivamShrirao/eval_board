# Server (Docker default uses hostname `postgres`)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/eval_board"

# Web
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080"
NEXT_PUBLIC_S3_PUBLIC_BASE=""

# Local image cache (used as fallback when S3 presigned URLs fail in the browser).
# Inside Docker the compose file mounts a named volume here.
IMAGE_CACHE_DIR="/opt/dlami/nvme/eval-board-cache"

# Site password gate. Default is `briaeval` if unset.
EVAL_BOARD_PASSWORD="briaeval"
# Secret used to sign the auth cookie. Override with a random string in prod.
AUTH_COOKIE_SECRET=""

# Server-side S3 URL signing (optional, defaults shown)
S3_PRESIGN_TTL_SECONDS="3600"
S3_PRESIGN_CACHE_REFRESH_WINDOW_SECONDS="120"
S3_PRESIGN_CACHE_MAX_ENTRIES="20000"
# Use AWS CLI profile + shared config mounted into Docker (`~/.aws` -> `/root/.aws`).
AWS_PROFILE="default"
# Optional explicit override if profile doesn't define a region:
# AWS_REGION="us-east-1"

# Secrets to be added later:
# AUTH_GOOGLE_CLIENT_ID=""
# AUTH_GOOGLE_CLIENT_SECRET=""
